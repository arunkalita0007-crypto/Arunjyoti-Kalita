rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function uidUnchanged() {
      return !('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid;
    }

    function uidNotModified() {
      return !('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidEntry(data) {
      return data.userId is string &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.type is string &&
             data.addedAt is string;
    }

    function isValidGoal(data) {
      return data.userId is string &&
             data.type is string &&
             data.target is number &&
             data.period is string &&
             data.createdAt is string;
    }

    function isValidList(data) {
      return data.userId is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.createdAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /entries/{entryId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidEntry(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidEntry(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /goals/{goalId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidGoal(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidGoal(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /lists/{listId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidList(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidList(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }
  }
}
