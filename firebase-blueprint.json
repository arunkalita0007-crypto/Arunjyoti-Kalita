{
  "entities": {
    "Entry": {
      "title": "Movie/Series Entry",
      "description": "A logged movie or series entry.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string" },
        "year": { "type": "number" },
        "director": { "type": "string" },
        "genre": { "type": "string" },
        "subGenre": { "type": "string" },
        "platform": { "type": "string" },
        "country": { "type": "string" },
        "language": { "type": "string" },
        "runtime": { "type": "number" },
        "episodesWatched": { "type": "number" },
        "imdbRating": { "type": "number" },
        "myRating": { "type": "number" },
        "status": { "type": "string" },
        "watchedDate": { "type": "string" },
        "review": { "type": "string" },
        "posterUrl": { "type": "string" },
        "addedAt": { "type": "string" }
      },
      "required": ["userId", "title", "type", "addedAt"]
    },
    "Goal": {
      "title": "User Goal",
      "description": "A movie watching goal.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "target": { "type": "number" },
        "current": { "type": "number" },
        "period": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "type", "target", "period", "createdAt"]
    },
    "CustomList": {
      "title": "Custom Movie List",
      "description": "A user-created list of movies.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "entryIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string" },
        "color": { "type": "string" }
      },
      "required": ["userId", "name", "createdAt"]
    }
  },
  "firestore": {
    "/entries/{entryId}": {
      "schema": "Entry",
      "description": "Collection of movie/series entries."
    },
    "/goals/{goalId}": {
      "schema": "Goal",
      "description": "Collection of user goals."
    },
    "/lists/{listId}": {
      "schema": "CustomList",
      "description": "Collection of custom movie lists."
    }
  }
}
